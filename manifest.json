{
  "manifest_version": 3,
  "name": "IAM BROWSER ADDON",
  "version": "1.0.0",
  "description": "Xtensible Web & App Identity Manager",
  "permissions": [
    "identity",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}